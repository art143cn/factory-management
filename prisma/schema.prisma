generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  documents     Document[]
  projects      Project[]
  tasks         Task[]
  partyMembers  PartyMember[]
  performances  Performance[]
}

model Document {
  id          String   @id @default(cuid())
  title       String
  category    String   // 管理制度 / 操作规程 / 技术文件
  content     String   @db.Text
  version     String   @default("v1.0")
  status      String   @default("draft") // draft / published / archived
  fileUrl     String?
  fileSize    Int?
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation(fields: [authorId], references: [id])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  status      String   @default("pending") // pending / ongoing / completed / abnormal
  priority    String   @default("medium")  // low / medium / high / urgent
  startDate   DateTime?
  endDate     DateTime?
  progress    Int      @default(0)         // 0-100
  managerId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager     User     @relation(fields: [managerId], references: [id])
  tasks       Task[]
  milestones  Milestone[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  status      String   @default("todo") // todo / in_progress / done
  priority    String   @default("medium")
  assigneeId  String
  projectId   String
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignee    User     @relation(fields: [assigneeId], references: [id])
  project     Project  @relation(fields: [projectId], references: [id])
}

model Milestone {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  targetDate  DateTime?
  completedAt DateTime?
  status      String   @default("pending") // pending / completed / delayed
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id])
}

model PartyMember {
  id          String   @id @default(cuid())
  name        String
  gender      String?  // male / female
  birthDate   DateTime?
  joinPartyAt DateTime?
  position    String?  // 党内职务
  education   String?
  phone       String?
  userId      String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  activities  PartyActivity[]
  studies     PartyStudy[]
}

model PartyActivity {
  id          String   @id @default(cuid())
  title       String
  type        String   // 三会一课 / 主题党日 / 民主生活会 / 其他
  date        DateTime
  location    String?
  content     String?  @db.Text
  memberId    String
  createdAt   DateTime @default(now())

  member      PartyMember @relation(fields: [memberId], references: [id])
}

model PartyStudy {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  duration    Int?     // 学习时长（分钟）
  content     String?  @db.Text
  score       Int?
  memberId    String
  createdAt   DateTime @default(now())

  member      PartyMember @relation(fields: [memberId], references: [id])
}

model Performance {
  id          String   @id @default(cuid())
  userId      String
  year        Int
  month       Int
  score       Float    @default(0)
  kpis        Json?    // 各维度 KPI 评分
  comment     String?  @db.Text
  status      String   @default("draft") // draft / submitted / approved
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}
